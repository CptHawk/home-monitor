# UniFi Protect (UDM-Pro/UDM-SE)
UNIFI_HOST=192.168.1.1
UNIFI_USERNAME=
UNIFI_PASSWORD=

# Google Nest (Device Access / SDM API)
# Setup guide: https://developers.google.com/nest/device-access
NEST_PROJECT_ID=
NEST_CLIENT_ID=
NEST_CLIENT_SECRET=
NEST_REFRESH_TOKEN=
NEST_ACCESS_TOKEN=

# Z-Wave JS UI
ZWAVE_HOST=localhost
ZWAVE_PORT=8091

# go2rtc
GO2RTC_HOST=localhost
GO2RTC_PORT=1984

# Weather Underground Personal Weather Station
WU_STATION_ID=
WU_API_KEY=6532d6454b8aa370768e63d6ba5a832e

# NWS Radar station (find yours at https://radar.weather.gov)
RADAR_STATION=KRAX

# Server host (used in Roku channel and OAuth callback)
SERVER_HOST=192.168.1.100
SERVER_PORT=8092
