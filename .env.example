# UniFi Protect (UDM-Pro/UDM-SE)
UNIFI_HOST=YOUR_UNIFI_IP
UNIFI_USERNAME=
UNIFI_PASSWORD=

# UniFi Network API (for network stats dashboard)
UNIFI_API_KEY=YOUR_UNIFI_API_KEY

# Google Nest (Device Access / SDM API)
# Setup guide: https://developers.google.com/nest/device-access
NEST_PROJECT_ID=
NEST_CLIENT_ID=
NEST_CLIENT_SECRET=
NEST_REFRESH_TOKEN=
NEST_ACCESS_TOKEN=

# Z-Wave JS UI
ZWAVE_HOST=localhost
ZWAVE_PORT=8091

# go2rtc
GO2RTC_HOST=localhost
GO2RTC_PORT=1984

# Weather Underground Personal Weather Station
WU_STATION_ID=YOUR_PWS_ID
WU_API_KEY=YOUR_WU_API_KEY

# NWS Radar station (find yours at https://radar.weather.gov)
RADAR_STATION=YOUR_RADAR_STATION

# Server host (used in Roku channel and OAuth callback)
SERVER_HOST=YOUR_SERVER_IP
SERVER_PORT=8092

# Samsara API (vehicle GPS/fuel telemetry)
# Create an API token at https://cloud.samsara.com/settings/api-tokens
SAMSARA_API_TOKEN=YOUR_SAMSARA_TOKEN

# Uconnect / Stellantis (EV charging, tire pressure, etc.)
UCONNECT_EMAIL=YOUR_UCONNECT_EMAIL
UCONNECT_PASSWORD=YOUR_UCONNECT_PASSWORD
UCONNECT_PIN=YOUR_UCONNECT_PIN

# Home coordinates (for vehicle geofencing "at home" detection)
HOME_LAT=YOUR_LAT
HOME_LON=YOUR_LON
